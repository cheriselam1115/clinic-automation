generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id               String   @id @default(uuid())
  name             String
  phoneNumber      String   // Twilio number assigned to this clinic (E.164)
  alertPhoneNumber String   // Receptionist's phone for instant SMS alerts (E.164)
  timezone         String   @default("America/New_York")
  address          String   @default("")
  logoUrl          String?
  settings         Json?    @default("{}")
  createdAt        DateTime @default(now())

  users            User[]
  patients         Patient[]
  appointments     Appointment[]
  reminderConfigs  ReminderConfig[]
  smsLogs          SmsLog[]
  waitlistEntries  WaitlistEntry[]

  @@map("clinics")
}

model User {
  id           String   @id @default(uuid())
  clinicId     String
  username     String   @unique
  passwordHash String
  name         String   @default("Receptionist")
  createdAt    DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("users")
}

model ReminderConfig {
  id           String   @id @default(uuid())
  clinicId     String
  hoursBefore  Int      // e.g. 192 = 8 days, 48 = 2 days, 2 = 2 hours
  label        String   // e.g. "8-day reminder" — shown in dashboard
  createdAt    DateTime @default(now())

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  reminderLogs ReminderLog[]

  @@map("reminder_configs")
}

model Patient {
  id                String   @id @default(uuid())
  clinicId          String
  name              String
  phoneNumber       String   // E.164 format e.g. +15551234567
  preferredLanguage String   @default("en") // 'en' | 'zh-TW' | 'yue'
  createdAt         DateTime @default(now())

  clinic           Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  smsLogs          SmsLog[]
  waitlistEntries  WaitlistEntry[]

  @@unique([clinicId, phoneNumber])
  @@map("patients")
}

model Appointment {
  id              String   @id @default(uuid())
  clinicId        String
  patientId       String
  appointmentAt   DateTime // stored in UTC
  appointmentType String
  status          String   @default("scheduled")
  // values: 'scheduled' | 'confirmed' | 'cancelled' | 'reschedule_requested' | 'no_response'
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reminderLogs ReminderLog[]
  smsLogs      SmsLog[]

  @@map("appointments")
}

model ReminderLog {
  id               String   @id @default(uuid())
  appointmentId    String
  reminderConfigId String
  sentAt           DateTime @default(now())
  twilioMessageSid String?

  appointment    Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  reminderConfig ReminderConfig @relation(fields: [reminderConfigId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, reminderConfigId]) // deduplication guarantee — prevents duplicate reminders
  @@map("reminder_logs")
}

model SmsLog {
  id               String   @id @default(uuid())
  clinicId         String
  appointmentId    String?
  patientId        String?
  direction        String   // 'inbound' | 'outbound'
  body             String
  fromNumber       String
  toNumber         String
  twilioMessageSid String?
  status           String?  // 'delivered' | 'failed' | 'received' etc.
  createdAt        DateTime @default(now())

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient     Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@map("sms_logs")
}

model WaitlistEntry {
  id                String    @id @default(uuid())
  clinicId          String
  patientId         String
  appointmentType   String?           // null = any type
  preferredDateFrom DateTime?         // start of acceptable date window (null = no limit)
  preferredDateTo   DateTime?         // end of acceptable date window (null = no limit)
  timePreference    String    @default("any") // any | morning | afternoon
  notes             String?
  // status: waiting | offered | booked | removed
  status            String    @default("waiting")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  clinic  Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  offers  WaitlistOffer[]

  @@map("waitlist_entries")
}

model WaitlistOffer {
  id              String   @id @default(uuid())
  waitlistEntryId String
  clinicId        String

  offeredApptAt   DateTime  // the slot being offered
  offeredApptType String?
  cancelledApptId String?   // original cancelled appointment ID — used for dedup

  offerExpiresAt  DateTime
  // status: pending | accepted | declined | expired
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  waitlistEntry WaitlistEntry @relation(fields: [waitlistEntryId], references: [id], onDelete: Cascade)

  @@map("waitlist_offers")
}
